{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "webapi",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--extra", "webapi", "python", "-c", "from embrapa_commodities.webapi.app import app; app.run(host='127.0.0.1', port=8000, threaded=True)"],
      "port": 8000
    },
    {
      "name": "frontend-react",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    },
    {
      "name": "frontend-build",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "preview", "--", "--port", "4173", "--strictPort"],
      "port": 4173
    }
  ]
}
