# Build context hygiene for any image built from this repo (context = root).
# Keeps the upload small and — critically — never ships secrets into a layer.

# Version control / tooling
.git
.github
.claude

# Python caches / virtualenvs
.venv
**/__pycache__
*.pyc
.pytest_cache
.ruff_cache
.mypy_cache

# Secrets & local env — NEVER bake these into an image
.env
.env.*
!.env.example

# dbt build artifacts
dbt/target
dbt/logs
dbt/dbt_packages

# Frontend host artifacts — the webapi image runs `npm ci` + `npm run build`
# inside the node stage; shipping host node_modules (platform-mismatched
# binaries) or a stale dist would overlay/poison that clean install.
frontend/node_modules
frontend/dist

# Misc
*.log
