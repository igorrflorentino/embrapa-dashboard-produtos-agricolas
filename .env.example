# Copy to .env and fill in. Never commit .env (already in .gitignore).
#
# Every name below — bucket, prefix, datasets, tables — is configurable so the
# project is portable (personal account → company account) without code changes.

# ─── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=embrapa-dashboard-commodities

# GCS bucket for the raw Parquet landing zone.
# Auto-created on first run. Defaults to "${GCP_PROJECT_ID}-datalake" when blank.
GCS_BUCKET=embrapa-dashboard-commodities-datalake

# Prefix inside the bucket. Final path is gs://${GCS_BUCKET}/${GCS_LANDING_PREFIX}/...
GCS_LANDING_PREFIX=landing

# BigQuery dataset location.
BQ_LOCATION=us-central1

# ─── BigQuery datasets / tables ───────────────────────────────────────────────
# All datasets and tables are auto-created on first ingestion.
BQ_BRONZE_IBGE_DATASET=bronze_ibge
BQ_BRONZE_BCB_DATASET=bronze_bcb
BQ_BRONZE_IBGE_TABLE=sidra_t289_raw
BQ_BRONZE_BCB_INFLATION_TABLE=inflation_series_raw
BQ_BRONZE_BCB_CURRENCY_TABLE=currency_series_raw
BQ_SILVER_DATASET=silver
BQ_GOLD_DATASET=gold

# ─── IBGE PEVS ────────────────────────────────────────────────────────────────
# Table 289 = Produção Extrativa Vegetal por município.
IBGE_TABLE_ID=289

# Classification 193 = Tipo de produto extrativo vegetal.
IBGE_CLASSIFICATION_ID=193

# Exact product codes (no keyword search at runtime — use
# `uv run embrapa discover ibge-products` to find codes interactively).
# Defaults: 3405 = Castanha-do-Brasil, 3435 = Madeira em tora, 3450 = Pinheiro brasileiro (em tora).
IBGE_PRODUCT_CODES=3405,3435,3450

# Year range. Use `uv run embrapa discover ibge-periods` to inspect availability.
# PEVS is published once a year with ~1-year lag — set IBGE_END_YEAR to a year
# you know has been published (bump it manually after each IBGE release).
IBGE_START_YEAR=1986
IBGE_END_YEAR=2024

# ─── BCB SGS ──────────────────────────────────────────────────────────────────
# Format: CODE:LABEL,CODE:LABEL,...
# Inflation series MUST be monthly percent change (the Silver layer chains them
# into a 100-base index).
#   433  = IPCA  (variação % mensal)
#   189  = IGP-M (variação % mensal)
#   190  = IGP-DI (variação % mensal)
BCB_INFLATION_SERIES=433:IPCA,189:IGPM,190:IGPDI

# FX series are BRL per foreign unit (daily). Triangulation between foreign
# currencies happens in Gold via BRL as pivot.
#   3694  = USD-to-BRL
#   4393  = EUR-to-BRL
#   20542 = CNY-to-BRL
BCB_CURRENCY_SERIES=3694:USD,4393:EUR,20542:CNY

BCB_START_YEAR=1980
BCB_END_YEAR=2026
