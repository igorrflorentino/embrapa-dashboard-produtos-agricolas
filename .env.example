# Copy to .env and fill in. Never commit .env (already in .gitignore).
#
# Every name below — bucket, prefix, datasets, tables — is configurable so the
# project is portable (personal account → company account) without code changes.

# ─── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=embrapa-dashboard-commodities

# GCS bucket for the raw Parquet data lake.
# Auto-created on first run. Defaults to "${GCP_PROJECT_ID}-datalake" when blank.
GCS_BUCKET=embrapa-dashboard-commodities-datalake

# Prefix for the two-phase raw zone — verbatim source extracts archived before
# Bronze (Phase 1). Final path is gs://${GCS_BUCKET}/${GCS_RAW_PREFIX}/<source>/...
GCS_RAW_PREFIX=raw

# BigQuery dataset location. Must match the region your datasets actually live
# in (and dbt/profiles.yml). If unset, config.py falls back to the "US"
# multi-region — keep this set to avoid a cross-region mismatch error.
BQ_LOCATION=us-central1

# Service Account to impersonate for developer workflows (dbt + ad-hoc queries).
# Use the FULL email (e.g. `sa-secret-reader-prod@${GCP_PROJECT_ID}.iam.gserviceaccount.com`)
# — the Python runtime passes this value VERBATIM as the impersonation target, so
# a short name breaks every ingest/doctor/backup with an opaque credentials error.
# (Only scripts/setup_dev_env.py expands a short name, and only while generating
# ~/.dbt/profiles.yml — not at runtime.) Leave blank to default to
# `sa-secret-reader-prod@${GCP_PROJECT_ID}.iam.gserviceaccount.com`.
GCP_IMPERSONATION_SA=

# ─── BigQuery datasets / tables ───────────────────────────────────────────────
# All datasets and tables are auto-created on first ingestion.
BQ_BRONZE_IBGE_DATASET=bronze_ibge
BQ_BRONZE_PAM_DATASET=bronze_pam
BQ_BRONZE_PPM_DATASET=bronze_ppm
BQ_BRONZE_BCB_DATASET=bronze_bcb
BQ_BRONZE_COMEX_DATASET=bronze_comex
BQ_BRONZE_IBGE_TABLE=sidra_t289_raw
BQ_BRONZE_PAM_TABLE=sidra_t5457_raw
# PPM spans two SIDRA tables → two Bronze tables (Silver unions them).
BQ_BRONZE_PPM_HERD_TABLE=sidra_t3939_raw
BQ_BRONZE_PPM_ANIMAL_TABLE=sidra_t74_raw
BQ_BRONZE_BCB_INFLATION_TABLE=inflation_series_raw
BQ_BRONZE_BCB_CURRENCY_TABLE=currency_series_raw
BQ_BRONZE_COMEX_FLOWS_TABLE=comex_flows_raw
# Un-prefixed dataset names. dbt's generate_schema_name macro adds the dev
# prefix automatically: dev target → dbt_dev_silver / dbt_dev_gold, prod →
# silver / gold. Keep BQ_GOLD_DATASET=gold — setting it to "dbt_dev_gold" here
# would double-prefix to dbt_dev_dbt_dev_gold in dev (and write prod to
# dbt_dev_gold). This var is also what `embrapa backup-gold` / doctor read.
BQ_SILVER_DATASET=silver
BQ_GOLD_DATASET=gold

# ─── IBGE PEVS ────────────────────────────────────────────────────────────────
# Table 289 = Extractive Vegetable Production by municipality.
IBGE_TABLE_ID=289

# Classification 193 = Type of extractive vegetable product.
IBGE_CLASSIFICATION_ID=193

# Exact product codes (no keyword search at runtime — use
# `uv run embrapa discover ibge-products` to find codes interactively).
# PEVS = EXTRACTIVE: 3405 Castanha-do-pará · 3435 Madeira em tora · 3434 Lenha ·
# 3433 Carvão vegetal · 3450 Pinheiro brasileiro (Araucária, em tora) · 3403 Açaí (fruto).
IBGE_PRODUCT_CODES=3405,3435,3434,3433,3450,3403

# Year range. Use `uv run embrapa discover ibge-periods` to inspect availability.
# PEVS is published once a year with ~1-year lag — set IBGE_END_YEAR to a year
# you know has been published (bump it manually after each IBGE release).
IBGE_START_YEAR=1986
IBGE_END_YEAR=2024

# Delta overlap (years). A routine `ingest ibge` / `ingest all` re-fetches only
# from (latest Bronze year - this) forward — absorbing PEVS revisions and a newly
# published year — instead of re-pulling 1986→today (which can blow SIDRA's
# slow-byte deadline on the unattended Cloud Run job). `--full` ignores this; a
# cold Bronze table falls back to the full window. For a first historical
# backfill use `make ingest-ibge-historical` (chunked).
IBGE_DELTA_OVERLAP_YEARS=1

# ─── IBGE PAM (Produção Agrícola Municipal — SIDRA table 5457) ────────────────
# The second IBGE/SIDRA source: ANNUAL crop production by municipality. Run on
# demand with `uv run embrapa ingest ibge-pam` (it is EXCLUDED from the nightly
# `ingest all` — annual, slow-changing data). Same delta/--full/--from-raw flags
# as `ingest ibge`.
PAM_TABLE_ID=5457
# Classification 782 = produto das lavouras temporárias e permanentes.
PAM_CLASSIFICATION_ID=782
# CULTIVATED crops (use `uv run embrapa discover ibge-products --table-id 5457`).
# 40124 Soja · 40122 Milho · 40139 Café (Total) · 40106 Cana-de-açúcar ·
# 40102 Arroz · 40136 Banana (cacho) · 40119 Mandioca · 45982 Açaí (cultivated).
PAM_PRODUCT_CODES=40124,40122,40139,40106,40102,40136,40119,45982
# Full PAM history (SIDRA 5457 runs to 1974). The monetary value is reform-correct
# via the historical_currency_factors join in silver_ibge_pam (Mil Cruzeiros/
# Cruzados/… → R$), so pre-1994 years are safe. First backfill is heavy — run
# `uv run embrapa ingest ibge-pam --full` once.
PAM_START_YEAR=1974
# PAM_END_YEAR is OPTIONAL: leave it unset (commented) and the end FLOATS with
# the current year, so a routine run absorbs revisions + picks up a new year.
# Setting a value PINS the window — the float stops until you bump it manually
# after each PAM release (same caveat as IBGE_END_YEAR above).
# PAM_END_YEAR=2024
PAM_DELTA_OVERLAP_YEARS=1

# ─── IBGE PPM (Pesquisa da Pecuária Municipal — SIDRA tables 3939 + 74) ───────
# The third IBGE/SIDRA source: ANNUAL livestock survey by municipality. Run on
# demand with `uv run embrapa ingest ibge-ppm` (EXCLUDED from nightly `ingest all`).
# PPM is multi-table: herd headcount (3939) + animal production (74), each ingested
# into its own Bronze table and unioned in silver_ibge_ppm.
#
# Table 3939 "Efetivo dos rebanhos" — herd HEADCOUNT (Cabeças, a STOCK, no value).
# Classification 79. Herd codes EXCLUDE the subset categories 32795 (Suíno-matrizes)
# and 32793 (Galináceos-galinhas), which are subsets of their "-total" parent.
PPM_HERD_TABLE_ID=3939
PPM_HERD_CLASSIFICATION_ID=79
PPM_HERD_PRODUCT_CODES=2670,2675,2672,32794,2681,2677,32796,2680
PPM_HERD_VARIABLE_CODES=105
# Table 74 "Produção de origem animal" — leite/ovos/mel/lã (a FLOW with value).
# Classification 80. Variables: 106 quantity + 215 value (Mil Reais 1994+). The
# 1000215 "percentual" series is intentionally excluded (a derived share).
PPM_ANIMAL_TABLE_ID=74
PPM_ANIMAL_CLASSIFICATION_ID=80
PPM_ANIMAL_PRODUCT_CODES=2682,2685,2686,2687,2683,2684
PPM_ANIMAL_VARIABLE_CODES=106,215
# Both tables run 1974→latest. PPM_END_YEAR is OPTIONAL: leave it unset and the end
# FLOATS with the current year (absorbs revisions + a new year). First backfill is
# heavy — run `uv run embrapa ingest ibge-ppm --full` once.
PPM_START_YEAR=1974
# PPM_END_YEAR=2024
PPM_DELTA_OVERLAP_YEARS=1

# ─── BCB SGS ──────────────────────────────────────────────────────────────────
# Format: CODE:LABEL,CODE:LABEL,...
# Inflation series MUST be monthly percent change (the Silver layer chains them
# into a 100-base index). LABELs become Gold column fragments (val_real_igpm_*),
# so they intentionally drop the hyphen of the official names (IGP-M → IGPM).
#   433  = IPCA   (monthly % change) → label IPCA
#   189  = IGP-M  (monthly % change) → label IGPM
#   190  = IGP-DI (monthly % change) → label IGPDI
BCB_INFLATION_SERIES=433:IPCA,189:IGPM,190:IGPDI

# Which series codes the Gold model uses for the val_real_ipca_* /
# val_real_igpm_* / val_real_igpdi_* projections. Must be one of the codes listed above.
BCB_INFLATION_SERIES_IPCA_CODE=433
BCB_INFLATION_SERIES_IGPM_CODE=189
BCB_INFLATION_SERIES_IGPDI_CODE=190

# FX series: daily PTAX "venda" rate, BRL per foreign unit. The Gold deflation
# averages these per year (PEVS) / per month (COMEX).
#   1      = USD-to-BRL  (PTAX "venda", daily — since 1984)
#   21619  = EUR-to-BRL  (PTAX "venda", daily — since 1999)
# Add a currency only if its SGS series is a real BRL-per-unit quote (verify
# with `uv run embrapa discover bcb-series <code>`).
BCB_CURRENCY_SERIES=1:USD,21619:EUR

BCB_START_YEAR=1980
# BCB_END_YEAR is OPTIONAL: leave it unset (commented) and the end FLOATS with the
# current year (config default). BCB FX/inflation are published continuously (no
# annual lag like IBGE), so floating keeps absorbing new months automatically.
# Pin it only to freeze the window for a reproducible historical run.
# BCB_END_YEAR=2026

# ─── COMEX (MDIC Comex Stat bulk CSV) ─────────────────────────────────────────
# Per-year, per-flow CSV files (EXP_<ano>.csv / IMP_<ano>.csv; ';'-separated,
# latin-1; history since 1997). We use the bulk CSV, NOT the JSON API: the API
# silently returned the aggregated Brazil total on a malformed filter (HTTP 200).
# Note: this host is outside the Claude Code on-the-web network allowlist — run
# COMEX ingestion locally.
COMEX_CSV_BASE_URL=https://balanca.economia.gov.br/balanca/bd/comexstat-bd/ncm

# Flows to ingest — closed domain {export, import}, mapped to EXP_/IMP_ prefixes.
COMEX_FLOWS=export,import

# Full 8-digit NCMs (exact). Format: CODE:LABEL,CODE:LABEL. Only for commodities
# whose HS4 heading is NOT clean: castanha (0801 also = coconut/cashew — and the
# MDIC NCM is 08012100/08012200 across the whole 1997+ series); açaí/cupuaçu (only
# the dedicated purê NCMs 2007.99.21/.26 are isolable — generic fruit buckets mix
# many fruits and are omitted); mandioca (spans 0714/1106/1108/1903, codes stable).
COMEX_NCM_CODES=08012100:castanha_com_casca,08012200:castanha_sem_casca,20079921:acai_pure,20079926:cupuacu_pure,07141000:mandioca_raiz,11062000:mandioca_farinha,11081400:mandioca_fecula,19030000:tapioca

# 2-digit HS chapters kept wholesale (every NCM starting with these digits).
# Empty — madeira moved to 4-digit headings below (drops manufactured wood).
COMEX_CHAPTER_CODES=

# 4-digit HS headings kept by prefix on NCM[:4] — captures EVERY NCM under the
# heading across all NCM revisions (so a code retired by a revision is still
# ingested; retired→current normalized in silver via comex_ncm_succession — e.g.
# soja 1201.00.90 pre-2017, banana 0803.00.00 pre-2012). Wood (raw/primary): 4401
# lenha · 4402 carvão · 4403 toras · 4407 serrada. Clean-heading commodities: 0803
# banana · 1005 milho · 1006 arroz · 1201 soja grão · 1507 soja óleo · 2304 soja farelo.
COMEX_HEADING_CODES=4401:madeira_lenha_residuos,4402:madeira_carvao,4403:madeira_tora,4407:madeira_serrada,0803:banana,1005:milho,1006:arroz,1201:soja_grao,1507:soja_oleo,2304:soja_farelo

# Comex history starts in 1997. COMEX_END_YEAR defaults to the current year and
# is always re-fetched on a delta run (the MDIC revises the running year monthly).
COMEX_START_YEAR=1997
COMEX_END_YEAR=2026

# ─── UN COMTRADE (global trade, keyed API) ────────────────────────────────────
# Free UN Comtrade key (register at https://comtradedeveloper.un.org/).
# It is a SECRET — fill it in here in your .env (gitignored); never commit it. In
# CI, use a GitHub secret. Empty = not configured (doctor warns, ingest errors clearly).
COMTRADE_API_KEY=
COMTRADE_API_BASE_URL=https://comtradeapi.un.org/data/v1/get
# COMTRADE Bronze dataset/table (auto-created on the 1st ingestion; read by
# doctor.BRONZE_TARGETS). They are NOT forwarded to the `ingest all` ingestion Job
# (COMTRADE is key-gated and stays out of `all` — runs separately with the key above).
BQ_BRONZE_COMTRADE_DATASET=bronze_comtrade
BQ_BRONZE_COMTRADE_FLOWS_TABLE=comtrade_flows_raw
# HS prefixes to keep (CODE:LABEL) — mirrors the COMEX scope to compare Brazil vs.
# the world on the same products. Prefixes of any length (ingestion expands each to
# its HS6 leaves). açaí/cupuaçu have NO isolable HS6 (purê falls in the mixed 200799
# bucket), so they are absent. Full history: the combined HS reference enumerates
# retired leaves under the 4-digit prefixes (banana 080300, soja 120100, old ch.44
# wood) automatically; only castanha's 080120 (pre-HS2007) is added explicitly
# (castanha uses exact 6-digit scope). Retired codes are translated to their current
# equivalent in silver (comtrade_hs_succession seed) → dashboard shows current only.
COMTRADE_CMD_CODES=080121:castanha_com_casca,080122:castanha_sem_casca,080120:castanha_historica,4401:madeira_lenha_residuos,4402:madeira_carvao,4403:madeira_tora,4407:madeira_serrada,0803:banana,071410:mandioca_raiz,110620:mandioca_farinha,110814:mandioca_fecula,190300:tapioca,1201:soja_grao,150710:soja_oleo_bruto,150790:soja_oleo_refinado,230400:soja_farelo,1005:milho,1006:arroz
# Flows (Comtrade flowCode): X=export, M=import, RX=re-export, RM=re-import.
COMTRADE_FLOWS=X,M,RX,RM
# Reporters: "all" (every reporting country, enumerated by the client) or an M49 list.
# DEFAULT "76" (Brazil): the pipeline fetches reporter × ALL partners, so a Brazil-only
# pull is Brazil's COMPLETE export/import history (cheap, within quota). The cross-source
# MIRROR + world market-share need every reporter's partner=Brazil rows → set "all" for
# the (expensive) global pull, or add a partnerCode-filtered mirror pass to the pipeline.
COMTRADE_REPORTERS=76
# ISO-A3 of the "home" reporter (Brazil) for the SERVING layer's Brazil-vs-world
# split (cross-source series exp_value/imp_value filter to this reporter;
# world_exp sums all reporters). Query-time only — never filters ingestion.
# Forwarded to the webapi Cloud Run Service by deploy/webapi/deploy.sh.
COMTRADE_BRAZIL_ISO=BRA
# Full history. Brazil reports to UN Comtrade from ~1989. The END floats with the
# current year (set a fixed value to pin it). The ingest is chunked + resume-aware:
# the scheduled monthly run chips away within the API quota, landing empty sentinels
# for past years with no data so they resume-skip. HS-revision caveat: banana
# (080300 pre-2012) / castanha (080120 pre-2007) have no rows before their 6-digit
# split until the retired codes are added (see config.py comtrade_start_year).
COMTRADE_START_YEAR=1989
# Leave COMTRADE_END_YEAR unset to float with the current year (default). Pin it to
# a fixed year only if you want to freeze the upper bound:
# COMTRADE_END_YEAR=2026
# SCHEDULED Comtrade backfill on the Cloud Run Job (deploy/ingestion/schedule_comtrade.sh).
# The Job can't read the UN key from .env — point COMTRADE_KEY_SECRET at the NAME
# of a Secret Manager secret that holds the key; deploy.sh mounts it (--set-secrets)
# only when set. Leave empty to keep Comtrade local-only (no scheduled backfill).
# See the schedule_comtrade.sh header for the create-secret + secretAccessor IAM steps.
# COMTRADE_KEY_SECRET=          # e.g. comtrade-un-key (a Secret Manager secret name)
# COMTRADE_SCHEDULE_CRON=0 4 15 * *
# COMTRADE_SCHEDULE_NAME=embrapa-ingest-all-comtrade-monthly
# COMTRADE_JOB_TASK_TIMEOUT=21600s

# ─── Cold-storage backup ──────────────────────────────────────────────────────
# `embrapa doctor` warns when the most recent gs://${GCS_BUCKET}/backups/
# snapshot is older than this. Default 14d matches a bi-weekly release cadence.
BACKUP_STALENESS_DAYS=14

# `embrapa backup-gold` introspects the Gold dataset and snapshots every table
# whose name starts with this prefix. Default "gold_" matches every dbt Gold
# table; tighten it if your Gold dataset also has ad-hoc tables that should
# NOT be backed up.
BACKUP_GOLD_PREFIX=gold_

# ─── Serving layer / dashboard data access ────────────────────────────────────
# Pre-aggregated marts + the SCD2 curation views the stateless Flask REST API
# (webapi — the React SPA's backend) reads via Pushdown Computing. Un-prefixed
# (dbt's generate_schema_name adds the dev prefix: dev → dbt_dev_serving, prod →
# serving). Point the deployed dashboard at "serving"; for local dev against dev
# data use "dbt_dev_serving".
BQ_SERVING_DATASET=serving

# Append-only researcher inputs (written by the dashboard, not dbt).
# Auto-created on first write (serving.attribute_engineering / serving.research_inputs ensure_* helpers).
BQ_RESEARCH_INPUTS_DATASET=research_inputs
# Per-CODE industrialization log (bruta/processada/misturado) — the primary
# curation grain; backs dim_code_industrialization_scd2 + the value-added analysis.
BQ_CODE_INDUSTRIALIZATION_LOG_TABLE=code_industrialization_log
# (customs procedure × flow) → economic-purpose market log (consumo/
# processamento) — the third curation log; backs the market-nature analysis.
BQ_FLOW_MARKET_LOG_TABLE=flow_market_log
# Per-banco maturity/coverage override (Console-managed) merged into /api/source-meta
# under the short curation TTL — lets an operator flip a banco's stage/note/coverage
# WITHOUT a redeploy. Sparse (only overridden bancos), auto-created on first write.
BQ_BANCO_METADATA_TABLE=banco_metadata
# Curadoria (catalog — what enters/exits the dashboard): the editable commodity catalog
# (replaces the commodity_crosswalk seed; → dim_commodity_catalog → gold_commodity_crosswalk),
# its PER-CATALOG editor allowlist, and the orphan→Descontinuado lifecycle log. All
# append-only in research_inputs, auto-created on first write. See PLANS/curadoria_catalogo.md.
BQ_COMMODITY_CATALOG_LOG_TABLE=commodity_catalog_log
BQ_CATALOG_EDITORS_TABLE=catalog_editors
BQ_CATALOG_LIFECYCLE_LOG_TABLE=catalog_lifecycle_log
# Append-only user feedback log (bug/dúvida/sugestão) — auto-created on first write.
BQ_FEEDBACK_LOG_TABLE=feedback_log
# "Loop fechado": when BOTH are set, each feedback report ALSO opens a GitHub issue
# (best-effort — a failure never blocks/loses the BigQuery write). Repo as "owner/name";
# the token should be a FINE-GRAINED token scoped to that one repo with Issues:write (NOT a
# broad classic PAT). In prod it lives in Secret Manager and deploy.sh mounts it as the
# FEEDBACK_GITHUB_TOKEN secret — see docs/operations_runbook.md. NEVER commit a token.
# Leave both unset to keep feedback BigQuery-only.
# FEEDBACK_GITHUB_REPO=igorrflorentino/embrapa-dashboard-commodities
# FEEDBACK_GITHUB_TOKEN=
# Per-author cooldown (seconds) on POST /api/feedback (debounces double-clicks/abuse); 0 = off.
# FEEDBACK_COOLDOWN_SECONDS=5

# ─── Cache (flask-caching) ────────────────────────────────────────────────────
# SimpleCache (per-instance) scales to N Cloud Run instances for FREE: marts
# converge within CACHE_DEFAULT_TIMEOUT (nightly data), and curation
# classifications use the SHORT CACHE_CLASSIFICATION_TIMEOUT below, so
# cross-instance staleness is bounded (eventual consistency ≤30s). RedisCache is
# optional — only for *instant* cross-instance consistency under high traffic.
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=600
CACHE_CLASSIFICATION_TIMEOUT=30
# CACHE_REDIS_URL=redis://10.0.0.3:6379/0

# Author email used ONLY when the IAP header is absent (local dev). Leave unset
# in production: IAP always supplies X-Goog-Authenticated-User-Email, and an
# unset fallback makes an un-attributed curation write fail loudly.
# CURATION_DEV_AUTHOR=you@example.com

# IAP backend audience — RECOMMENDED in production to arm the in-app IAP JWT
# double-check (the curation author then comes from the cryptographically VERIFIED
# X-Goog-IAP-JWT-Assertion). With the prod posture (Cloud Run DIRECT IAP) the
# platform already authenticates every request and OVERWRITES
# X-Goog-Authenticated-User-Email with the verified identity, so author capture is
# trustworthy even when this is UNSET — the in-app check is defense-in-depth, not
# load-bearing. Find the value in Console → Security → Identity-Aware Proxy → ⋮ on
# the Cloud Run resource → "Get JWT audience code" (the direct-IAP form). Only the
# FUTURE external-HTTPS-LB + IAP topology would use the backendServices form
#   /projects/<PROJECT_NUMBER>/global/backendServices/<BACKEND_SERVICE_ID>
# Leave unset for local dev (no IAP — the plaintext header is spoofable only there).
# Forwarded to the webapi Service by deploy/webapi/deploy.sh.
# See docs/operations_runbook.md + serving/iap.py.
# IAP_AUDIENCE=

# Curator ALLOWLIST (authorization, distinct from IAP authentication). When set,
# ONLY these emails may POST a curation edit (others get 403). Comma-separated.
# Leave UNSET (default) to keep current behaviour: any IAP-authenticated caller
# may curate. Set it once researchers are onboarded to lock writes down.
# CURATION_ALLOWED_EMAILS=curator1@embrapa.br,curator2@embrapa.br

# Console-managed curator allowlist TABLE (research_inputs.<this>) — the no-redeploy
# alternative to CURATION_ALLOWED_EMAILS above. Add/remove a curator by INSERT/DELETE
# of an `email` row in the BigQuery Console; changes take effect within the short
# classification cache TTL. The effective allowlist is the UNION of this table and
# CURATION_ALLOWED_EMAILS; if BOTH are empty/absent, any IAP-authenticated caller
# may curate. Auto-created (serving.research_inputs.ensure_curators_table).
BQ_CURATORS_TABLE=curators

# Per-query byte ceiling for the /api serving path (gateway.run_query):
# caps a pathological/cold scan so BigQuery FAILS the job visibly instead of
# silently billing a runaway read. Default ~100 GiB (107374182400). Tune to your
# data sizes; set 0 to disable.
# BQ_MAX_BYTES_BILLED=107374182400

# ─── Ingestion Cloud Run Job (deploy-time; deploy/ingestion/) ─────────────────
# Consumed by deploy/ingestion/{deploy,schedule}.sh — NOT read by the Python app.
# All optional; defaults are baked into the scripts. Uncomment to override.
# INGEST_JOB_REGION is the Cloud Run region — a SINGLE region, default
# us-central1. It is DECOUPLED from BQ_LOCATION on purpose: Cloud Run rejects a
# BigQuery multi-region locator ("US"/"EU"), so set a concrete region here if
# your datasets aren't in the US. ("US"/"EU" are auto-mapped to us-central1 /
# europe-west1; any other multi-region is rejected with a clear error.)
# INGEST_JOB_REGION=us-central1
# INGEST_JOB_NAME=embrapa-ingest-all
# INGEST_JOB_AR_REPO=embrapa-jobs
# INGEST_JOB_SA=sa-data-pipeline-prod@embrapa-dashboard-commodities.iam.gserviceaccount.com
# INGEST_JOB_TASK_TIMEOUT=3600s
# INGEST_JOB_MEMORY=2Gi
# INGEST_SCHEDULE_CRON=0 5 * * *
# INGEST_SCHEDULE_TZ=America/Sao_Paulo
# Service account Cloud Scheduler uses to call the Job's :run endpoint (needs
# run.invoker on the Job; the reconcile/comtrade triggers additionally need
# run.jobsExecutorWithOverrides). Read by all three schedule scripts
# (schedule.sh / schedule_reconcile.sh / schedule_comtrade.sh).
# INGEST_SCHEDULE_SA=sa-data-pipeline-prod@embrapa-dashboard-commodities.iam.gserviceaccount.com
# Monthly deep-refresh (make ingest-job-reconcile-schedule): the SAME Job run
# with args overridden to `reconcile` — a full re-ingest that catches upstream
# corrections to OLD years the nightly delta skips. Heavier, so its own timeout.
# RECONCILE_SCHEDULE_CRON=0 3 1 * *
# RECONCILE_SCHEDULE_NAME=embrapa-ingest-all-reconcile-monthly
# RECONCILE_JOB_TASK_TIMEOUT=7200s
# Recipient(s) for the ingestion-job failure alert (required by `make ingest-job-alert`).
# Comma-separated for multiple — each address gets its own notification channel.
# INGEST_ALERT_EMAIL=ops@example.com,lead@example.com
# INGEST_ALERT_CHANNEL_NAME=Embrapa ingestion alerts

# ─── Webapi Cloud Run Service (deploy-time; deploy/webapi/) ───────────────────
# Consumed by deploy/webapi/deploy.sh (`make webapi-deploy`) — NOT read by the
# Python app. All optional; defaults are baked into the script.
# WEBAPI_REGION is read from this .env (or the shell env); like
# INGEST_JOB_REGION it must be a concrete Cloud Run region ("US"/"EU" are
# auto-mapped to us-central1 / europe-west1). Default us-central1.
# WEBAPI_REGION=us-central1
# The remaining knobs are SHELL-ENV overrides only (export before running
# `make webapi-deploy`; deploy.sh does not read them from .env):
#   WEBAPI_SERVICE_NAME   (default embrapa-dashboard — in-place cutover)
#   WEBAPI_AR_REPO        (default embrapa-services)
#   WEBAPI_SA             (default sa-web-dashboard-prod@<project>.iam.gserviceaccount.com)
#   WEBAPI_TAG            (default: short git SHA)
#   WEBAPI_MEMORY / WEBAPI_CPU / WEBAPI_CONCURRENCY (defaults 1Gi / 1 / 16)
#   WEBAPI_MIN_INSTANCES / WEBAPI_MAX_INSTANCES     (defaults 0 / 4)
#   WEBAPI_GOLD_DATASET / WEBAPI_SERVING_DATASET    (defaults gold / serving —
#     the deploy forces the PROD datasets; the BQ_*_DATASET values above are
#     deliberately NOT forwarded, a dev .env often points them at dev datasets)
# Runtime env forwarded from this .env by the deploy allowlist: GCP_PROJECT_ID,
# BQ_LOCATION, CACHE_*, IAP_AUDIENCE, COMTRADE_BRAZIL_ISO,
# CURATION_ALLOWED_EMAILS, BQ_MAX_BYTES_BILLED.
