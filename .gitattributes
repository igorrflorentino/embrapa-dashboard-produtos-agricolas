# Force LF on text files so Windows checkouts (core.autocrlf=true) don't break
# shell scripts and other tools that choke on \r.
* text=auto eol=lf

# Files that MUST stay LF regardless of platform.
*.sh        text eol=lf
*.bash      text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
Makefile    text eol=lf

# Windows-native scripts keep CRLF.
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary — never touch.
*.parquet   binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
